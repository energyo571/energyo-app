rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Only authenticated users can access storage
    // Lead attachments: scoped to team folder
    match /leads/{teamId}/{leadId}/{fileName} {
      // Read: user must be signed in and belong to the team
      allow read: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.teamId == teamId;

      // Write: user must be signed in, belong to the team, file max 10 MB
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.teamId == teamId
        && request.resource.size < 10 * 1024 * 1024;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
